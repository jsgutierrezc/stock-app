# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # service_role key (server only, NEVER expose)

# api-football (RapidAPI). Suscríbete en https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=YOUR_RAPIDAPI_KEY
API_FOOTBALL_HOST=v3.football.api-sports.io
# League id de api-football para Mundial: 1 — temporada 2026
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# Token de admin para endpoints sensibles (sync, recalc). Genera uno largo y aleatorio.
ADMIN_TOKEN=cambia-esto-por-un-token-largo

# Código de invitación del primer admin. Lo verás en la pantalla de login.
SEED_ADMIN_CODE=NATIADMIN
SEED_ADMIN_NAME=Sebastián
